# ============================================
# AIOps Multi-Agent System - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your .env file to version control!
# ============================================

# --------------------------------------------
# AWS Configuration
# --------------------------------------------
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=us-east-1

# --------------------------------------------
# ServiceNow Configuration
# --------------------------------------------
SERVICENOW_INSTANCE=your-instance.service-now.com
SERVICENOW_USER=your-username
SERVICENOW_PASS=your-password

# --------------------------------------------
# AgentCore Deployment
# --------------------------------------------
EXECUTION_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/AgentCoreExecutionRole
AWS_REGION=us-east-1
AGENT_NAME=aiopsagentcoreapp # Must start with a letter, contain only letters/numbers/underscores, and be 1-48 characters long.
ECR_REPOSITORY=590183838803.dkr.ecr.us-east-1.amazonaws.com/aiopsagentcoreapp
CODEBUILD_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/AgentCoreCodeBuildRole
AGENTCORE_AGENT_RUNTIME_ARN=agentcore-runtime-arn
